<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Headers Game Tracker</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>

    <div class="container">
        
        <!-- ========================= TIMER / CONTROLS PANEL ========================= -->
        <div class="control-panel">
            <div class="timer-display">
                <div class="timer-label">Game Time Remaining</div>
                <div id="countdown-display" class="timer-value">---</div>
            </div>

            <div class="timing-controls">
                <button id="start-btn" class="btn start-btn">Start Game</button>
                <button id="cancel-btn" class="btn cancel-btn" disabled>Cancel</button>
            </div>
        </div>

        <!-- ========================= SCORING BOARD ========================= -->
        <div class="scoring-board">
            
            <!-- LOCAL TEAM SIDE -->
            <div class="team-side local">
                <h3>Local Team</h3>
                
                <!-- 1. PIN TRACKING (10 Boxes) -->
                <div class="pin-scoring">
                    <h4>Pin Progress (1-10)</h4>
                    <div class="pin-grid local-pins" id="local-pins">
                        <!-- 10 checkbox elements will be populated by JS -->
                    </div>
                </div>

                <!-- 2. SCORE INPUT (23 Slots) -->
                <div class="score-slots">
                    <p>Score (1-23):</p>
                    <!-- Radio buttons will be generated by JS -->
                </div>
                
                <!-- 3. ACTION BUTTONS (Tickers) -->
                <div class="action-buttons">
                    <h4>Tick Box Action</h4>
                    <button id="btn-local-1" class="action-btn team-btn team-local" data-team="local" data-pin="1">Pin 1</button>
                    <button id="btn-local-2" class="action-btn team-btn team-local" data-team="local" data-pin="2">Pin 2</button>
                    <!-- ... repeat for Pin 3 through Pin 10 -->
                    <button id="btn-local-10" class="action-btn team-btn team-local" data-team="local" data-pin="10">Pin 10</button>
                </div>
            </div>

            <!-- CENTRAL SCORE TRACKING (The 23 Numbers) -->
            <div class="score-tracker">
                <h2>Headers Score</h2>
                <div class="score-grid" id="score-grid">
                    <!-- 23 numbered columns will be populated by JS -->
                </div>
            </div>
            
            <!-- VISITOR TEAM SIDE -->
            <div class="team-side visitor">
                <h3>Visitor Team</h3>

                <!-- 1. PIN TRACKING (10 Boxes) -->
                <div class="pin-scoring">
                    <h4>Pin Progress (1-10)</h4>
                    <div class="pin-grid visitor-pins" id="visitor-pins">
                         <!-- 10 checkbox elements will be populated by JS -->
                    </div>
                </div>

                <!-- 2. SCORE INPUT (23 Slots) -->
                <div class="score-slots">
                    <p>Score (1-23):</p>
                    <!-- Radio buttons will be generated by JS -->
                </div>
                
                <!-- 3. ACTION BUTTONS (Tickers) -->
                <div class="action-buttons">
                    <h4>Tick Box Action</h4>
                    <button id="btn-visitor-1" class="action-btn team-btn team-visitor" data-team="visitor" data-pin="1">Pin 1</button>
                    <button id="btn-visitor-2" class="action-btn team-btn team-visitor" data-team="visitor" data-pin="2">Pin 2</button>
                    <!-- ... repeat for Pin 3 through Pin 10 -->
                    <button id="btn-visitor-10" class="action-btn team-btn team-visitor" data-team="visitor" data-pin="10">Pin 10</button>
                </div>
            </div>
        </div>
        
        <!-- ========================= GLOBAL CONTROLS ========================= -->
        <div class="global-controls">
            <button id="clear-all-btn" class="btn clear-btn">Clear All Scores</button>
        </div>

    </div>

    <script src="script.js"></script>
</body>
</html>

